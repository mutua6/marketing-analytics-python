   "source": [
    "# CTR — how often people click after seeing the ad\n",
    "df['CTR'] = (df['clicks'] / df['impressions'] * 100).round(2)\n",
    "\n",
    "# CPC — how much each click costs\n",
    "df['CPC'] = (df['spend'] / df['clicks']).round(2)\n",
    "\n",
    "# ROAS — revenue generated for every $1 spent\n",
    "df['ROAS'] = (df['revenue'] / df['spend']).round(2)\n",
    "\n",
    "# Conversion Rate — clicks that became conversions\n",
    "df['conv_rate'] = (df['conversions'] / df['clicks'] * 100).round(2)\n",
    "\n",
    "df[['campaign_name', 'date', 'spend', 'CTR', 'CPC', 'ROAS', 'conv_rate']]"
   ]
  },
