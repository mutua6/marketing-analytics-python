   "source": [
    "# Fix 1 — convert date from text to proper datetime\n",
    "df['date'] = pd.to_datetime(df['date'], dayfirst=True)\n",
    "\n",
    "# Fix 2 — replace UNKNOWN with NaN so the column becomes numeric\n",
    "df['conversions'] = df['conversions'].replace('UNKNOWN', pd.NA)\n",
    "df['conversions'] = pd.to_numeric(df['conversions'])\n",
    "\n",
    "# Fix 3 — fill missing impressions with the median of that campaign\n",
    "df['impressions'] = df.groupby('campaign_name')['impressions'] \\\n",
    "                      .transform(lambda x: x.fillna(x.median()))\n",
    "\n",
    "# Convert impressions to integer now that nulls are gone\n",
    "df['impressions'] = df['impressions'].astype(int)\n",
    "\n",
    "print(\"After cleaning:\")\n",
    "print(df.dtypes)\n",
    "print(f\"\\nNulls remaining:\\n{df.isnull().sum()}\")"
   ]
